# ─── Database ────────────────────────────────────────────────────────────────
# Local SQLite (dev): sqlite+aiosqlite:///./vf_crm.db
# Supabase Postgres: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL=sqlite+aiosqlite:///./vf_crm.db

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-32-char-string-in-production
ACCESS_TOKEN_EXPIRE_HOURS=12

# Set to "true" in production to require auth on all endpoints
AUTH_REQUIRED=false

# ─── CORS ────────────────────────────────────────────────────────────────────
# In production: restrict to your frontend domain
# Example: https://crm.vazquezefonseca.com.br,https://www.vazquezefonseca.com.br
CORS_ORIGINS=*

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ─── Monitoring (optional) ───────────────────────────────────────────────────
SENTRY_DSN=

# ─── Enrichment APIs (placeholders) ──────────────────────────────────────────
CNPJWS_API_KEY=
APOLLO_API_KEY=
SERASA_API_KEY=
SANCOR_API_URL=
BERKLEY_API_URL=
ZURICH_API_URL=

# ─── Email (future) ──────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
